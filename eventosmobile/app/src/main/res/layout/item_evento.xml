<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="#FFFFFF">

    <TextView android:id="@+id/tvNombre" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Nombre evento" android:textStyle="bold" android:textSize="18sp" android:textColor="#0F172A"/>

    <TextView android:id="@+id/tvSub" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="6dp" android:text="Ubicación • Fecha" android:textSize="14sp" android:textColor="#64748B"/>
</LinearLayout>
