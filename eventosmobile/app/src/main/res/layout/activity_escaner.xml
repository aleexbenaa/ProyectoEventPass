<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F1F5F9">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Escáner QR" android:textStyle="bold" android:textSize="24sp" android:textColor="#0F172A"/>

    <TextView android:id="@+id/tvEventoSeleccionado" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:text="Evento: " android:textColor="#64748B" android:textSize="15sp"/>

    <Button android:id="@+id/btnAbrirCamara" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="22dp" android:text="Abrir cámara" android:textAllCaps="false"
        android:backgroundTint="#2563EB" android:textColor="#FFFFFF"/>
</LinearLayout>
