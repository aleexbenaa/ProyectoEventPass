<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F1F5F9">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Selecciona un evento" android:textSize="22sp" android:textStyle="bold" android:textColor="#0F172A"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="4dp" android:text="Elige el evento que vas a validar" android:textSize="14sp" android:textColor="#64748B"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEventos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"/>
</LinearLayout>
